# ============================================
# TradingEdge - Environment
# ============================================

# OpenAI API Key (required for LLM reasoning)
OPENAI_API_KEY=sk-your-openai-api-key-here

# NewsAPI Key (free at https://newsapi.org/register)
NEWS_API_KEY=your-newsapi-key-here

# Brave Search API Key (optional — enables web_search tool)
# Free tier: 2000 queries/month — https://brave.com/search/api/
BRAVE_API_KEY=

# ============================================
# Trading Mode
# ============================================
# "live" = real money trading via brokers | "paper" = simulated trading
TRADING_MODE=paper
# Enable auto-execution of trading signals (requires TRADING_MODE=live)
AUTO_TRADING_ENABLED=false

# ============================================
# Interactive Brokers (IBKR)
# ============================================
# TWS or IB Gateway must be running locally
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_MODE=paper

# ============================================
# CommSec (Commonwealth Securities — ASX)
# ============================================
# Apply for API access at https://www.commsec.com.au
COMMSEC_CLIENT_ID=
COMMSEC_CLIENT_SECRET=
COMMSEC_ACCOUNT_ID=
COMMSEC_REFRESH_TOKEN=

# ============================================
# IG Markets (CFDs + Share Trading)
# ============================================
# API docs: https://labs.ig.com/
IG_API_KEY=
IG_USERNAME=
IG_PASSWORD=
IG_ACCOUNT_ID=

# ============================================
# CMC Markets
# ============================================
# API docs: https://www.cmcmarkets.com/en-au/trading-guides/cmc-markets-api
CMC_API_KEY=
CMC_USERNAME=
CMC_PASSWORD=
CMC_ACCOUNT_ID=

# ============================================
# SelfWealth
# ============================================
# API docs: https://www.selfwealth.com.au
SELFWEALTH_API_KEY=
SELFWEALTH_CLIENT_ID=
SELFWEALTH_SECRET=
SELFWEALTH_ACCOUNT_ID=

# ============================================
# Stripe (billing — optional)
# ============================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# PostgreSQL Database
DATABASE_URL=postgresql+asyncpg://trading_user:trading_pass@localhost:5432/trading_db

# Redis (for caching & task queue)
REDIS_URL=redis://localhost:6379/0

# Application Settings
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-this-to-a-random-secret-key

# Scheduler Settings (interval in minutes)
SCHEDULER_INTERVAL=30
WATCHLIST=AAPL,MSFT,GOOGL,AMZN,TSLA,NVDA,META,CBA.AX,BHP.AX,WBC.AX

# LLM Settings
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# ============================================
# Risk Management
# ============================================
MAX_LOSS_PER_TRADE_PCT=2.0
DAILY_LOSS_LIMIT_PCT=5.0
WEEKLY_LOSS_LIMIT_PCT=10.0
MAX_POSITION_PCT=10.0
AUTO_STOP_LOSS_PCT=3.0
MAX_DRAWDOWN_PCT=15.0
MAX_SINGLE_ORDER_VALUE=100000
MAX_DAILY_ORDERS=200
MAX_OPEN_POSITIONS=50

# ============================================
# Streamlit Cloud Secrets (set via dashboard)
# ============================================
# API_BASE_URL=https://multiagent-trading-system.vercel.app
# VERCEL_AUTOMATION_BYPASS_SECRET=<same value set in Vercel env vars>
