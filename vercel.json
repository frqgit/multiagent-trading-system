{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "vercel_app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "vercel_app.py"
    }
  ],
  "env": {
    "OPENAI_API_KEY": "@openai-api-key",
    "NEWS_API_KEY": "@news-api-key",
    "DATABASE_URL": "@database-url",
    "REDIS_URL": "@redis-url",
    "SECRET_KEY": "@secret-key",
    "APP_ENV": "production"
  }
}
