# ============================================
# Streamlit Cloud Secrets
# Copy these values to Streamlit Cloud → App Settings → Secrets
# ============================================

# Vercel backend URL (your production Vercel deployment)
API_BASE_URL = "https://multiagent-trading-system-frqgits-projects.vercel.app"

# Vercel Deployment Protection bypass secret
# Must match VERCEL_AUTOMATION_BYPASS_SECRET in Vercel env vars
VERCEL_AUTOMATION_BYPASS_SECRET = "your-bypass-secret-here"
